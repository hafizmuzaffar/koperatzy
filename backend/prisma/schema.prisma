generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Anggota {
  id           String   @id @default(uuid())
  nama         String
  alamat       String?
  jenisKelamin String
  sbu          String
  tglMasuk     DateTime @default(now())
  status       String   @default("Aktif")
  
  simpananPokok Float @default(0)
  simpananWajib Float @default(0)

  alasanKeluar String?
  tglKeluar    DateTime?

  tabungan          Tabungan[]
  pinjaman          Pinjaman[]
  transaksiAnggota  TransaksiAnggota[]
}

model TransaksiAnggota {
  id        String   @id @default(uuid())
  anggotaId String
  tgl       DateTime @default(now())
  jenis     String
  nominal   Float

  anggota   Anggota @relation(fields: [anggotaId], references: [id], onDelete: Cascade)
}

model Tabungan {
  id           String   @id @default(uuid())
  anggotaId    String
  noRekening   String   @unique
  bank         String   @default("Mandiri")
  saldoPokok   Float    @default(0)
  saldoWajib   Float    @default(0)
  saldoSukarela Float   @default(0)
  status       String   @default("Aktif")
  tglBuka      DateTime @default(now())

  anggota      Anggota  @relation(fields: [anggotaId], references: [id], onDelete: Cascade)
  transaksi    TransaksiTabungan[]
}

model TransaksiTabungan {
  id           String   @id @default(uuid())
  tabunganId   String
  tgl          DateTime @default(now())
  jenis        String
  jenisSimpanan String?
  keterangan   String?
  nominal      Float

  tabungan     Tabungan @relation(fields: [tabunganId], references: [id], onDelete: Cascade)
}

model Pinjaman {
  id               String   @id @default(uuid())
  anggotaId        String
  tglPengajuan     DateTime @default(now())
  nominalPinjaman  Float
  tenorBulan       Int
  tujuan           String?
  status           String   @default("Pengajuan")

  anggota          Anggota  @relation(fields: [anggotaId], references: [id], onDelete: Cascade)
  transaksi        TransaksiPinjaman[]
}

model TransaksiPinjaman {
  id           String   @id @default(uuid())
  pinjamanId   String
  tgl          DateTime @default(now())
  jenis        String
  nominal      Float

  pinjaman     Pinjaman @relation(fields: [pinjamanId], references: [id], onDelete: Cascade)
}
